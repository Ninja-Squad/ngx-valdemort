{
  "name": "ngx-valdemort",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build --project ngx-valdemort",
    "watch": "ng build --project ngx-valdemort --watch --configuration development",
    "test": "ng test --watch=false --project ngx-valdemort",
    "build:demo": "ng build --project demo",
    "test:demo": "ng test --watch=false --project demo",
    "postinstall": "pnpm exec playwright install",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "doc": "node scripts/prepare-doc.js && cd projects/ngx-valdemort && compodoc",
    "release": "cd projects/ngx-valdemort && commit-and-tag-version --infile ../../CHANGELOG.md",
    "format": "prettier --write ./"
  },
  "private": true,
  "packageManager": "pnpm@11.6.0",
  "dependencies": {
    "@angular/cdk": "22.0.1",
    "@angular/common": "22.0.1",
    "@angular/compiler": "22.0.1",
    "@angular/core": "22.0.1",
    "@angular/forms": "22.0.1",
    "@angular/material": "22.0.1",
    "@angular/platform-browser": "22.0.1",
    "@angular/platform-server": "22.0.1",
    "@angular/router": "22.0.1",
    "@angular/ssr": "22.0.1",
    "@ng-bootstrap/ng-bootstrap": "20.0.0",
    "@popperjs/core": "2.11.8",
    "bootstrap": "5.3.8",
    "express": "5.2.1",
    "font-awesome": "4.7.0",
    "rxjs": "7.8.2",
    "shiki": "4.2.0",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@angular-eslint/builder": "22.0.0",
    "@angular/build": "22.0.1",
    "@angular/cli": "22.0.1",
    "@angular/compiler-cli": "22.0.1",
    "@angular/localize": "22.0.1",
    "@compodoc/compodoc": "1.2.1",
    "@eslint/js": "10.0.1",
    "@types/express": "5.0.6",
    "@types/node": "24.13.2",
    "@vitest/browser": "4.1.9",
    "@vitest/browser-playwright": "4.1.9",
    "@vitest/eslint-plugin": "^1.6.9",
    "@vitest/spy": "4.1.9",
    "angular-eslint": "22.0.0",
    "commit-and-tag-version": "12.7.3",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "ng-packagr": "22.0.0",
    "playwright": "1.60.0",
    "prettier": "3.8.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1",
    "vitest": "4.1.9"
  }
}
