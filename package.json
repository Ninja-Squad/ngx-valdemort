{
  "name": "ngx-valdemort",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build --project ngx-valdemort",
    "watch": "ng build --project ngx-valdemort --watch --configuration development",
    "test": "ng test --watch=false --project ngx-valdemort",
    "build:demo": "ng build --project demo",
    "test:demo": "ng test --watch=false --project demo",
    "postinstall": "pnpm exec playwright install",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "doc": "node scripts/prepare-doc.js && cd projects/ngx-valdemort && compodoc",
    "release": "cd projects/ngx-valdemort && commit-and-tag-version --infile ../../CHANGELOG.md",
    "format": "prettier --write ./"
  },
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@angular/cdk": "21.2.4",
    "@angular/common": "21.2.6",
    "@angular/compiler": "21.2.6",
    "@angular/core": "21.2.6",
    "@angular/forms": "21.2.6",
    "@angular/material": "21.2.4",
    "@angular/platform-browser": "21.2.6",
    "@angular/platform-server": "21.2.6",
    "@angular/router": "21.2.6",
    "@angular/ssr": "21.2.4",
    "@ng-bootstrap/ng-bootstrap": "20.0.0",
    "@popperjs/core": "2.11.8",
    "bootstrap": "5.3.8",
    "express": "5.2.1",
    "font-awesome": "4.7.0",
    "rxjs": "7.8.2",
    "shiki": "4.0.2",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@angular-eslint/builder": "21.3.1",
    "@angular/build": "21.2.4",
    "@angular/cli": "21.2.4",
    "@angular/compiler-cli": "21.2.6",
    "@angular/localize": "21.2.6",
    "@compodoc/compodoc": "1.2.1",
    "@eslint/js": "9.39.4",
    "@types/express": "5.0.6",
    "@types/node": "24.12.0",
    "@vitest/browser": "4.1.2",
    "@vitest/browser-playwright": "4.1.2",
    "@vitest/eslint-plugin": "^1.6.9",
    "@vitest/spy": "4.1.2",
    "angular-eslint": "21.3.1",
    "commit-and-tag-version": "12.7.1",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "ng-packagr": "21.2.1",
    "playwright": "1.58.2",
    "prettier": "3.8.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.2",
    "vitest": "4.1.2"
  }
}
